{
  "name": "trade-plus",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "./dev.sh",
    "dev:turbo": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "setup": "npm install && cd apps/api && npm run setup"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
