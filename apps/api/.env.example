# Trade-Plus API Configuration

TRADEPLUS_DEBUG=true
TRADEPLUS_LOG_LEVEL=INFO

# Redis (hot cache)
REDIS_HOST=localhost
REDIS_PORT=6380

# TimescaleDB (signals, predictions, pipeline runs)
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5434
TIMESCALE_USER=tradeplus
TIMESCALE_PASSWORD=changeme
TIMESCALE_DATABASE=tradeplus_market

# PostgreSQL (orders, trades, positions)
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_USER=tradeplus
POSTGRES_PASSWORD=changeme
POSTGRES_DATABASE=tradeplus_trades

# Broker (mock for dev, zerodha for prod)
BROKER_NAME=mock
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ACCESS_TOKEN=

# AI - xAI Grok (X/Twitter sentiment, trending, web search)
XAI_API_KEY=

# AI - Parallel AI (real-time news search with deduplication)
PARALLEL_API_KEY=

# Risk limits
RISK_MAX_POSITION_SIZE=100
RISK_MAX_DAILY_LOSS=5000
RISK_MAX_OPEN_POSITIONS=5
RISK_MAX_ORDERS_PER_SECOND=8
RISK_MAX_ORDER_VALUE=500000
